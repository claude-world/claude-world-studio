{
  "name": "@claude-world/studio",
  "version": "2.2.0",
  "type": "module",
  "description": "Claude World Studio - Trend Discovery to Content Publishing Pipeline",
  "main": "electron/main.cjs",
  "bin": {
    "claude-world-studio": "bin/cli.js",
    "studio": "bin/cli.js",
    "setup-mcp": "bin/setup-mcp.sh"
  },
  "files": [
    "bin/",
    "client/",
    "server/",
    "scripts/before-pack.js",
    "scripts/electron-build.cjs",
    "electron/",
    "postcss.config.js",
    "tsconfig.json",
    "vite.config.ts",
    ".env.example"
  ],
  "keywords": [
    "claude",
    "ai",
    "agent",
    "threads",
    "social-media",
    "trend-analysis",
    "mcp",
    "anthropic"
  ],
  "author": "Claude World <hello@claude-world.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/claude-world/claude-world-studio.git"
  },
  "homepage": "https://github.com/claude-world/claude-world-studio",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/server.ts",
    "dev:client": "vite --port 5173",
    "postinstall": "npm rebuild better-sqlite3 2>/dev/null; true",
    "start": "tsx server/server.ts",
    "build": "vite build",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && node scripts/electron-build.cjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yml,yaml,css}\"",
    "test": "npx tsx --test test/*.test.ts",
    "test:cli": "node bin/cli.js help > /dev/null",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.claude-world.studio",
    "productName": "Claude World Studio",
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "**"
    ],
    "electronVersion": "41.1.0",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg",
      "identity": "Wang LongWei (QJX3775S8M)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "files": [
      "bin/**/*",
      "electron/**/*",
      "server/**/*",
      "scripts/**/*",
      "dist/index.html",
      "dist/assets/**/*",
      "data/**/*",
      ".env",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data"
      }
    ]
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.85",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "tsx": "^4.19.0",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.0.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-use-websocket": "^4.13.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
