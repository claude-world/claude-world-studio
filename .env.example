# Claude World Studio Configuration
# Copy to .env and fill in your values

# ─── Server ───
PORT=3001
HOST=127.0.0.1

# ─── UI Preferences ───
# Language: en, zh-TW, ja
# LANGUAGE=zh-TW
# Theme: light, dark, system
# THEME=light

# ─── MCP Servers ───
# All are optional — the app works with any combination.
# If uvx is installed, Studio auto-detects MCP servers with zero config.
# These settings override uvx auto-detection.

# trend-pulse: real-time trends from 20 sources (zero auth needed)
# Setup: uvx (auto) or git clone + pip install
# TREND_PULSE_PYTHON=/path/to/trend-pulse/.venv/bin/python

# cf-browser: Cloudflare Browser Rendering for JS pages
# Two modes available — set CF_BROWSER_MODE to choose:
#   cf-api  (default) — uses Cloudflare API directly
#   worker  — uses a deployed Cloudflare Worker

# CF_BROWSER_MODE=cf-api
# CF_BROWSER_PYTHON=/path/to/cf-browser/mcp-server/.venv/bin/python

# Mode: cf-api (recommended — simpler setup)
# CF_ACCOUNT_ID=your-cloudflare-account-id
# CF_API_TOKEN=your-cloudflare-api-token

# Mode: worker (requires deploying a Worker first)
# CF_BROWSER_URL=https://your-cf-browser.workers.dev
# CF_BROWSER_API_KEY=your-api-key

# notebooklm: Google NotebookLM research + podcast/slides/video
# Setup: uvx (auto) or git clone + pip install + Google login
# NOTEBOOKLM_SERVER_PATH=/path/to/notebooklm-skill/mcp-server/server.py

# ─── Social Publishing (optional) ───
# Configure via Settings UI for easier management.
# Or set here for headless/CLI use:
# THREADS_TOKEN=your-threads-access-token
# THREADS_USER_ID=your-user-id

# ─── Quality Gates ───
# MIN_OVERALL_SCORE=70
# MIN_CONVERSATION_SCORE=55

# ─── Workspace ───
# DEFAULT_WORKSPACE=/path/to/your/workspace
